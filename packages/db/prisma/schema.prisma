generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────

enum LlmProvider {
  openai
  deepseek
}

enum ChunkingStrategy {
  fixed
  semantic
}

enum MessageRole {
  user
  assistant
}

enum MessageFeedback {
  positive
  negative
}

enum DocumentStatus {
  pending
  processing
  done
  failed
}

enum DocumentFiletype {
  txt
  md
}

enum EvalMetric {
  faithfulness
  answer_relevancy
  context_precision
}

// ── Settings (key-value store) ───────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}

// ── Conversations ────────────────────────────────────────────────────

model Conversation {
  id        String    @id @default(uuid()) @db.Uuid
  title     String    @default("")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  messages  Message[]

  @@map("conversations")
}

// ── Messages ─────────────────────────────────────────────────────────

model Message {
  id              String           @id @default(uuid()) @db.Uuid
  conversationId  String           @map("conversation_id") @db.Uuid
  role            MessageRole
  content         String
  feedback        MessageFeedback?
  retrievedChunks Json?            @map("retrieved_chunks")
  prompt          String?          // Serialized LLMMessage[] JSON for observability
  ttftMs          Int?             @map("ttft_ms")
  totalMs         Int?             @map("total_ms")
  retrievalMs     Int?             @map("retrieval_ms")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  evaluations     Evaluation[]

  @@index([conversationId])
  @@map("messages")
}

// ── Documents ────────────────────────────────────────────────────────

model Document {
  id                    String           @id @default(uuid()) @db.Uuid
  filename              String
  fileType              DocumentFiletype @map("file_type")
  storagePath           String           @map("storage_path")
  status                DocumentStatus   @default(pending)
  errorMessage          String?          @map("error_message")
  chunkingStrategy      ChunkingStrategy @default(fixed) @map("chunking_strategy")
  chunkSize             Int              @map("chunk_size")
  chunkOverlap          Int              @map("chunk_overlap")
  totalChunks           Int?             @map("total_chunks")
  processedChunks       Int?             @map("processed_chunks")
  processingStartedAt   DateTime?        @map("processing_started_at") @db.Timestamptz
  processingCompletedAt DateTime?        @map("processing_completed_at") @db.Timestamptz
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  beirSource            String?          @map("beir_source") // BEIR dataset name if injected
  chunks                Chunk[]

  @@map("documents")
}

// ── Chunks ───────────────────────────────────────────────────────────

model Chunk {
  id         String                      @id @default(uuid()) @db.Uuid
  documentId String                      @map("document_id") @db.Uuid
  content    String
  embedding  Unsupported("public.vector(1024)")
  chunkIndex Int                         @map("chunk_index")
  metadata   Json?
  createdAt  DateTime                    @default(now()) @map("created_at") @db.Timestamptz
  document   Document                    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  // @@index([embedding(ops: HnswOps)], map: "chunks_embedding_idx", type: Hnsw)
  @@map("chunks")
}

// ── Evaluations ──────────────────────────────────────────────────────

model Evaluation {
  id        String     @id @default(uuid()) @db.Uuid
  messageId String     @map("message_id") @db.Uuid
  metric    EvalMetric
  score     Decimal    @db.Decimal(3, 2)
  reason    String?
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  message   Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("evaluations")
}

// ── BEIR Evaluation ──────────────────────────────────────────────────

model BeirCorpus {
  id        String            @id @default(uuid()) @db.Uuid
  dataset   String
  beirDocId String            @map("beir_doc_id")
  title     String?
  text      String
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz
  chunks    BeirCorpusChunk[]

  @@unique([dataset, beirDocId])
  @@index([dataset])
  @@map("beir_corpus")
}

model BeirCorpusChunk {
  id             String                @id @default(uuid()) @db.Uuid
  corpusId       String                @map("corpus_id") @db.Uuid
  chunkIndex     Int                   @map("chunk_index")
  content        String
  chunkingConfig String                @map("chunking_config")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz
  corpus         BeirCorpus            @relation(fields: [corpusId], references: [id], onDelete: Cascade)
  embeddings     BeirCorpusEmbedding[]

  @@unique([corpusId, chunkIndex, chunkingConfig])
  @@index([corpusId, chunkingConfig])
  @@map("beir_corpus_chunks")
}

model BeirCorpusEmbedding {
  id        String                     @id @default(uuid()) @db.Uuid
  chunkId   String                     @map("chunk_id") @db.Uuid
  model     String
  embedding Unsupported("vector(1024)")
  createdAt DateTime                   @default(now()) @map("created_at") @db.Timestamptz
  chunk     BeirCorpusChunk            @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([chunkId, model])
  @@index([model])
  @@map("beir_corpus_embeddings")
}

model BeirQuery {
  id          String @id @default(uuid()) @db.Uuid
  dataset     String
  beirQueryId String @map("beir_query_id")
  text        String

  @@unique([dataset, beirQueryId])
  @@map("beir_queries")
}

model BeirQrel {
  dataset   String
  queryId   String @map("query_id")
  docId     String @map("doc_id")
  relevance Int

  @@id([dataset, queryId, docId])
  @@map("beir_qrels")
}

model BeirEvalRun {
  id              String              @id @default(uuid()) @db.Uuid
  dataset         String
  embeddingConfig String              @map("embedding_config")
  sampleSize      Int                 @map("sample_size")
  metrics         Json
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz
  queryDetails    BeirEvalRunDetail[]

  @@index([dataset, createdAt])
  @@map("beir_eval_runs")
}

model BeirEvalRunDetail {
  id              String      @id @default(uuid()) @db.Uuid
  runId           String      @map("run_id") @db.Uuid
  queryId         String      @map("query_id")
  queryText       String      @map("query_text")
  hits            Json
  ndcg10          Decimal     @map("ndcg10") @db.Decimal(5, 4)
  relevantInTop10 Int         @map("relevant_in_top10")
  run             BeirEvalRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("beir_eval_run_details")
}

// ── Prompt Templates ─────────────────────────────────────────────────

model PromptTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  content   String
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("prompt_templates")
}
