# ── E2E Test Environment ──────────────────────────────────────────────────────
# Copy this file to .env.test and fill in real values (same as .env with 3 changes below).
# .env.test is gitignored — do NOT commit it.
#
# Changes from .env:
#   1. DATABASE_URL  → append ?schema=test
#   2. STORAGE_BUCKET=test-documents
#   3. REDIS_KEY_PREFIX={e2e}

# ── LLM (same as .env) ────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX={e2e}

# ── Supabase Local ────────────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=<paste from .env>

# ★ Add ?schema=test to isolate test data from dev schema
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?schema=test

# ★ Use dedicated test bucket (created automatically by globalSetup)
STORAGE_BUCKET=test-documents

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
JOB_RETRY_COUNT=3

# ── File Limits ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── Embedding Sidecar (e2e tests don't call LLM/embedding — keep default) ─────
EMBEDDING_SERVICE_URL=http://localhost:8000
