# ── LLM ──────────────────────────────────────────────────────────────
LLM_API_KEY="use DEEPSEEK_API_KEY or OPENAI_API_KEY"
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

DEEPSEEK_API_KEY=
OPENAI_API_KEY=


# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase Local ───────────────────────────────────────────────────
# Run `supabase start` to get these values
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
STORAGE_BUCKET=test-documents

# ── Redis ───────────────────────────────────────────────────────────
REDIS_KEY_PREFIX={e2e}

# ── Worker ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
JOB_RETRY_COUNT=3

# ── File Limits ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ── Embedding Sidecar ────────────────────────────────────────────────
# Python FastAPI service (BGE-M3 on GPU). Run via docker-compose.dev.yml
EMBEDDING_SERVICE_URL=http://localhost:8000

# ── API ──────────────────────────────────────────────────────────────
PORT=3001
# Frontend origin for CORS (dev)
CORS_ORIGIN=http://localhost:5173
