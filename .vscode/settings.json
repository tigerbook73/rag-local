    },
    {
      "ssh": "Disabled",
      "previewLimit": 50,
      "server": "localhost",
      "driver": "PostgreSQL",
      "name": "RAG Local - Public",
      "connectString": "postgresql://postgres:postgres@127.0.0.1:54322/postgres"
    }
  ]
