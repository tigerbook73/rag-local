{
  "name": "@rag-local/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch --exec 'node --env-file=../../.env'",
    "debug": "nest start --watch --exec 'node --inspect --env-file=../../.env'",
    "build": "nest build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "gen:spec": "nest build && node dist/gen-spec.js ../../openapi.json"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@rag-local/core": "workspace:*",
    "@rag-local/db": "workspace:*",
    "@supabase/supabase-js": "^2.50.0",
    "bullmq": "^5.54.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.3.0",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@swc/core": "^1.15.41",
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "supertest": "^7.1.0",
    "typescript": "^5.8.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
}
